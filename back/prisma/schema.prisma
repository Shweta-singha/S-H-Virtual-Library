generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  image     String?
  googleId  String   @unique

  createdAt DateTime @default(now())
}

model Room {
  id        String   @id @default(cuid())
  code      String   @unique
  createdAt DateTime @default(now())
}

model StudySession {
  id        String   @id @default(cuid())
  userEmail String
  startedAt DateTime
  endedAt   DateTime?
  duration  Int?
  createdAt DateTime @default(now())
}